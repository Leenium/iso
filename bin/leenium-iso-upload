#!/bin/bash

if [ $# -eq 0 ]; then
  echo "Usage: leenium-iso-upload [release/leenium.iso]"
  exit 1
fi

if [[ ! -f ~/.config/rclone/rclone.conf ]]; then
  echo "You must first configure rclone with the R2 credentials: leenium-iso-rclone-config"
  exit 1
fi

rclone copy $1 Leenium:leenium/ -P

if [[ -f $1.sig ]]; then
  rclone copy $1.sig Leenium:leenium/ -P
fi
