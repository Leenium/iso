#!/bin/bash
leenium-pkg-add rclone
mkdir -p ~/.config/rclone

if ! command -v bw >/dev/null 2>&1; then
  echo "Bitwarden CLI is required. Install it with: leenium-pkg-add bitwarden-cli"
  exit 1
fi

if [[ $(bw status | jq -r '.status') != "unlocked" ]]; then
  echo "Unlock Bitwarden first: bw login && bw unlock"
  exit 1
fi

# Expected Bitwarden item names:
# - iso.leenium.drunkleen.com access_key_id
# - iso.leenium.drunkleen.com secret_access_key
# - iso.leenium.drunkleen.com endpoint
access_key=$(bw get password "iso.leenium.drunkleen.com access_key_id")
secret_access_key=$(bw get password "iso.leenium.drunkleen.com secret_access_key")
endpoint=$(bw get password "iso.leenium.drunkleen.com endpoint")

cat > ~/.config/rclone/rclone.conf << EOF
[Leenium]
type = s3
provider = Cloudflare
access_key_id = $access_key
secret_access_key = $secret_access_key
endpoint = $endpoint
EOF
